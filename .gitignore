# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Secrets / tokens (never commit a credential)
.env
.env.*
*.key
*.pem
*token*
*secret*

# Robot data: episodes (parquet) and recordings (mp4) are NOT redistributed here.
*.parquet
*.mp4
*.npz
*.safetensors
# Manufacturer URDFs are fetched into the user cache by robot_descriptions, never vendored.
# (tests/fixtures/urdf/*.urdf are hand-authored synthetic fixtures and ARE tracked.)

# Quarantined failures (kept, never deleted)
experiments/_wip/

# Test / cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# tracecal is a LIBRARY: consumers resolve deps via pip and CI uses fresh resolution.
# No committed lockfile (avoids pinning the heavy [physics]/[hub] transitive closure
# and the unfixable transitive CVEs that come with it). Run `uv lock` locally if needed.
uv.lock

# Internal autonomous-build resume state (local only; not part of the public package)
.tracecal-progress.json
