<?xml version="1.0"?>
<!-- Hand-authored synthetic 3-DOF arm: 2 revolute + 1 prismatic, mixed limits.
     NOT derived from any manufacturer model. Apache-2.0. One joint (j_free) is
     continuous (no limit) and must be ignored by the limited-joint extraction. -->
<robot name="synth_3dof_mixed">
  <link name="base"/>
  <link name="l1"/>
  <link name="l2"/>
  <link name="l3"/>
  <link name="l4"/>
  <joint name="rev1" type="revolute">
    <parent link="base"/>
    <child link="l1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" velocity="1.5" effort="5.0"/>
  </joint>
  <joint name="prism1" type="prismatic">
    <parent link="l1"/>
    <child link="l2"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.3" velocity="0.5" effort="20.0"/>
  </joint>
  <joint name="rev2" type="revolute">
    <parent link="l2"/>
    <child link="l3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" velocity="2.5" effort="5.0"/>
  </joint>
  <joint name="j_free" type="continuous">
    <parent link="l3"/>
    <child link="l4"/>
    <axis xyz="0 0 1"/>
  </joint>
</robot>
